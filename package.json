{
  "name": "@well-architectured-tools/well-architectured-framework",
  "version": "0.0.1",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "prettier": "@well-architectured-tools/prettier-config",
  "scripts": {
    "develop": "npm run infra:up && npm run clear:server && npm run assets && tsc-watch --noClear -p tsconfig.build.json --onSuccess \"npm run start\"",
    "clear:server": "rm -rf ./dist/server && rm -rf ./dist/.tmp/server",
    "clear:test": "rm -rf ./dist/test && rm -rf ./dist/.tmp/test",
    "build:server": "tsc -p tsconfig.build.json",
    "build:test": "tsc -p tsconfig.test.json",
    "assets": "mkdir -p dist/server && cp -r assets/. dist/server/",
    "start": "node --inspect --enable-source-maps dist/server/index.js",
    "format:check": "prettier ./src --check",
    "format:write": "prettier ./src --write",
    "lint:check": "eslint ./src",
    "lint:write": "eslint ./src --fix",
    "lint:inspect-config": "eslint --inspect-config",
    "unit-tests": "vitest --config ./vitest.config.ts --project unit-tests",
    "infra-tests": "npm run clear:test && npm run build:test && vitest --config ./vitest.config.ts --project infra-tests",
    "use-case-tests": "npm run clear:test && npm run build:test && vitest --config ./vitest.config.ts --project use-case-tests",
    "e2e-tests": "npm run clear:test && npm run build:test && vitest --config ./vitest.config.ts --project e2e-tests",
    "e2e-tests:dev": "export E2E_BASE_URL=http://127.0.0.1:3000 && npm run clear:test && npm run build:test && vitest --config ./vitest.config.ts --project e2e-tests",
    "infra:up": "docker compose -f infra/compose-databases.yaml up -d",
    "infra:down": "docker compose -f infra/compose-databases.yaml down -v",
    "pg-migrations:base": "node-pg-migrate --config-file=migrations/postgres/config.json --database-url-var=POSTGRES_URL",
    "pg-migrations:create": "npm run pg-migrations:base -- create migration",
    "pg-migrations:up": "npm run pg-migrations:base -- up",
    "prepare": "ts-patch install"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@novadi/core": "^0.6.0",
    "dotenv-safe": "^9.1.0",
    "fastify": "^5.8.5",
    "pg": "^8.18.0",
    "pino": "^10.3.0",
    "typia": "^12.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tsconfig/node-ts": "^23.6.2",
    "@tsconfig/node24": "^24.0.3",
    "@tsconfig/strictest": "^2.0.8",
    "@types/dotenv-safe": "^9.1.0",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@well-architectured-tools/prettier-config": "^1.0.1",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^5.3.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "node-pg-migrate": "^8.0.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "testcontainers": "^11.13.0",
    "ts-patch": "^3.3.0",
    "tsc-watch": "^7.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.51.0",
    "vitest": "^4.0.16"
  }
}
